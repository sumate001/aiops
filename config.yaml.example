http:
  addr: "0.0.0.0:8200"

logger:
  level: "info"   # debug | info | warning | error

godeye:
  callback_url: null        # POST AnalyzeResponse กลับหา GodEye เช่น "http://godeye:9000/api/aiops/callback"
  callback_timeout: "10s"
  enabled: true             # false = ไม่ส่ง webhook แม้จะมี callback_url

aiops_ml:
  base_url: "http://aiops-ml:8100"
  timeout: "60s"
  enabled: true    # false = skip ML, วิเคราะห์ด้วย Ollama อย่างเดียว

log_ml:
  base_url: "http://localhost:3050"   # A1 Isolation Forest service
  timeout: "10s"
  enabled: true

perplexica:
  base_url: "http://localhost:3001"   # A2 Perplexica (SearXNG + AI synthesis)
  chat_model: "gemma4:e4b"            # ต้องมีใน Ollama (ดู /api/tags)
  embedding_model: "nomic-embed-text:latest"
  timeout: "480s"   # A2 ช้าเมื่อ Ollama รันบน CPU (~10 tok/s) — เผื่อ 4-7 นาที/host
  enabled: true     # false = ข้าม external search enrichment

ollama:
  base_url: "http://localhost:11434"   # remote เช่น http://100.x.x.x:11434 (Tailscale)
  model: "gemma4:e4b"        # ปรับตาม model ที่ deploy ไว้ (ดู /api/tags)
  timeout: "120s"
  temperature: 0.1            # ต่ำ = consistent, factual

# AI judge gateway (MiroFish + AA Synthesizer enrichment).
# provider: "ollama" ใช้ native /api/generate; provider อื่น = OpenAI-compatible
# (groq, cerebras, gemini, openrouter, mistral, cohere, sambanova, nvidia,
#  github, siliconflow, llm7, ovhcloud — ดู app/services/llm_providers.py)
# ดูรายชื่อ free APIs: https://github.com/mnfst/awesome-free-llm-apis
llm:
  enabled: false                       # เปิดเพื่อให้ LLM enrich (ปิด = rule-based เท่านั้น)
  # ── Default AI: ทุก stage ใช้ค่านี้ ถ้าไม่เปิด override ของ stage นั้น ──
  provider: "ollama"                   # หรือ groq / cerebras / gemini / openrouter ...
  base_url: "http://localhost:11434"   # OpenAI-compat: เช่น https://api.groq.com/openai/v1
  model: "gemma4:e4b"                  # เช่น llama-3.3-70b-versatile (groq)
  api_key: null                        # หรือ set ผ่าน env (เช่น GROQ_API_KEY)
  timeout: "120s"
  temperature: 0.1
  # ── Per-stage override: ตั้ง override: true เพื่อใช้ provider/model ต่างจาก default ──
  mirofish:    { override: false, provider: "ollama", base_url: "http://localhost:11434", model: "gemma4:e4b", api_key: null }
  synthesizer: { override: false, provider: "ollama", base_url: "http://localhost:11434", model: "gemma4:e4b", api_key: null }
  # perplexica: เปลี่ยนเฉพาะ chat model ของ A2 (embedding ยังใช้ ollama/transformers ในเครื่อง)
  perplexica:  { override: false, provider: "ollama", base_url: "http://localhost:11434", model: "gemma4:e4b", api_key: null }

analysis:
  max_log_entries: 500        # cap per request ป้องกัน OOM
  severity_filter: "warn"     # รับเฉพาะ warn ขึ้นไป (info = เยอะเกิน)
  health_score:
    critical_weight: 2.0      # error/fatal นับหนักกว่า warn
    warn_weight: 1.0
    score_floor: 0.0
    score_ceiling: 100.0
