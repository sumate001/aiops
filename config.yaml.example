http:
  addr: "0.0.0.0:8200"

logger:
  level: "info"   # debug | info | warning | error

godeye:
  callback_url: null        # POST AnalyzeResponse กลับหา GodEye เช่น "http://godeye:9000/api/aiops/callback"
  callback_timeout: "10s"
  enabled: true             # false = ไม่ส่ง webhook แม้จะมี callback_url

aiops_ml:
  base_url: "http://aiops-ml:8100"
  timeout: "60s"
  enabled: true    # false = skip ML, วิเคราะห์ด้วย Ollama อย่างเดียว

log_ml:
  base_url: "http://localhost:3050"   # A1 Isolation Forest service
  timeout: "10s"
  enabled: true

perplexica:
  base_url: "http://localhost:3001"   # A2 Perplexica/Vane (SearXNG + AI synthesis)
  chat_model: "gemma4:e4b"            # legacy (embedding-side); chat model มาจาก llm.perplexica
  embedding_model: "Xenova/all-MiniLM-L6-v2"   # Transformers (local, ในตัว Vane) ไม่ต้องพึ่ง Ollama
  mode: "speed"     # Vane optimizationMode — speed = เสถียร + ได้ web sources บนโมเดลฟรี
                    # (balanced/quality อาจค้างจาก tool-use loop บน Groq free models)
  timeout: "90s"    # speed mode ตอบ ~20s/host
  enabled: true     # false = ข้าม external search enrichment

ollama:
  base_url: "http://localhost:11434"   # remote เช่น http://100.x.x.x:11434 (Tailscale)
  model: "gemma4:e4b"        # ปรับตาม model ที่ deploy ไว้ (ดู /api/tags)
  timeout: "120s"
  temperature: 0.1            # ต่ำ = consistent, factual

# AI judge gateway (MiroFish + AA Synthesizer enrichment).
# provider: "ollama" ใช้ native /api/generate; provider อื่น = OpenAI-compatible
# (groq, cerebras, gemini, openrouter, mistral, cohere, sambanova, nvidia,
#  github, siliconflow, llm7, ovhcloud — ดู app/services/llm_providers.py)
# ดูรายชื่อ free APIs: https://github.com/mnfst/awesome-free-llm-apis
llm:
  enabled: true                        # เปิดเพื่อให้ LLM enrich (ปิด = rule-based เท่านั้น)
  # ── Default AI (ค่าที่ทดสอบแล้วทำงานได้ฟรี): Groq llama-3.3-70b ──
  # ทุก stage ใช้ค่านี้ ถ้าไม่เปิด override ของ stage นั้น
  provider: "groq"                     # หรือ ollama / cerebras / gemini / openrouter ...
  base_url: "https://api.groq.com/openai/v1"
  model: "llama-3.3-70b-versatile"     # รองรับ tool/JSON ดีสำหรับ MiroFish + Synthesizer
  api_key: null                        # set ผ่าน env GROQ_API_KEY หรือใส่ที่นี่
  timeout: "120s"
  temperature: 0.1
  # ── Per-stage override: ตั้ง override: true เพื่อใช้ provider/model ต่างจาก default ──
  mirofish:    { override: false, provider: "groq", base_url: "https://api.groq.com/openai/v1", model: "llama-3.3-70b-versatile", api_key: null }
  synthesizer: { override: false, provider: "groq", base_url: "https://api.groq.com/openai/v1", model: "llama-3.3-70b-versatile", api_key: null }
  # perplexica (A2): Vane ต้องการโมเดลที่ทำได้ทั้ง strict json_schema + tool-calling —
  # openai/gpt-oss-20b (Groq) คือตัวที่ทดสอบแล้วผ่านครบ (scout/llama-3.3/qwen ใช้ไม่ได้)
  perplexica:  { override: true, provider: "groq", base_url: "https://api.groq.com/openai/v1", model: "openai/gpt-oss-20b", api_key: null }

analysis:
  max_log_entries: 500        # cap per request ป้องกัน OOM
  severity_filter: "warn"     # รับเฉพาะ warn ขึ้นไป (info = เยอะเกิน)
  health_score:
    critical_weight: 2.0      # error/fatal นับหนักกว่า warn
    warn_weight: 1.0
    score_floor: 0.0
    score_ceiling: 100.0
  # เกณฑ์ของ metric ที่ GodEye ส่งมา (entry type="metric") → กลายเป็น anomaly
  # key = substring ของชื่อ metric (case-insensitive, match อันที่ยาว/เจาะจงสุด)
  # direction: above = breach เมื่อ value >= threshold, below = value <= threshold
  # ถ้าไม่กำหนด จะใช้ค่า default ในโค้ด (cpu/memory/disk/load/latency/error_rate/temperature)
  metric_thresholds:
    cpu:        { warn: 80, critical: 95, direction: above, unit: percent }
    memory:     { warn: 85, critical: 95, direction: above, unit: percent }
    disk_usage: { warn: 85, critical: 95, direction: above, unit: percent }
    disk_free:  { warn: 15, critical: 5,  direction: below, unit: percent }
    latency:    { warn: 500, critical: 1000, direction: above, unit: ms }
